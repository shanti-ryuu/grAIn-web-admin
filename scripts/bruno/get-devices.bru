meta {
  name: Get All Devices
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/devices
}

headers {
  Authorization: Bearer {{token}}
}

assert {
  res.status: eq 200
  res.body.isArray: true
}

docs {
  Retrieves all devices assigned to the current user.
  Admin users see all devices.
  Requires JWT authentication.
}
